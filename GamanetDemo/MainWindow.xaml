<Window x:Class="GamanetDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GamanetDemo"
        d:DataContext="{d:DesignInstance Type=local:MainWindowViewModel}"
        mc:Ignorable="d"
        Title="Gamanet Demo - Persons" Height="600" Width="800">
    <Grid x:Name="RootContainer">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <TextBlock Text="Filter by Country:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="CountryFilter" Width="200"
                      ItemsSource="{Binding Countries}"
                      SelectionChanged="CountryFilter_SelectionChanged"/>
            <TextBlock Text="Sort by:" VerticalAlignment="Center" Margin="20,0,5,0"/>
            <Button Content="Name" Click="SortByName_Click" Padding="15,5" Margin="5,0"/>
            <Button Content="Country" Click="SortByCountry_Click" Padding="15,5" Margin="5,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10,0,10,10">
            <ItemsControl ItemsSource="{Binding FilteredPersons}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="5" Padding="10" BorderBrush="#CCCCCC" BorderThickness="1"
                                Background="#F5F5F5" CornerRadius="3" Width="160">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                           TextWrapping="Wrap" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding Country}"
                                           Foreground="#555555" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding Phone}"
                                           Foreground="#777777"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>