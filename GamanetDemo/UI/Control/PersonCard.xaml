<UserControl x:Class="GamanetDemo.UI.Control.PersonCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:model="clr-namespace:GamanetDemo.Model"
             d:DataContext="{d:DesignInstance Type=model:PersonEntity}"
             mc:Ignorable="d"
             d:DesignWidth="160">
    <Grid x:Name="RootContainer">
        <Border Padding="10" 
                BorderBrush="#CCCCCC" 
                BorderThickness="1"
                Background="#F5F5F5"
                CornerRadius="3">
            <StackPanel>
                <TextBlock Text="{Binding Name}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Margin="0,0,0,4"/>
                <TextBlock Text="{Binding Country}"
                           Foreground="#555555"
                           Margin="0,0,0,2"/>
                <TextBlock Text="{Binding Phone}"
                           Foreground="#777777"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>